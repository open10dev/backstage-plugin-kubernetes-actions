  "devDependencies": {
    "@backstage/backend-test-utils": "^1.2.0",
    "@backstage/cli": "^0.36.0",
    "@types/express": "^4.17.6",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "files": [
    "dist"
