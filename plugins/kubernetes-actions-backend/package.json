  "repository": {
    "type": "git",
    "url": "https://github.com/ruchit-mac/backstage-plugin-kubernetes-actions",
    "directory": "plugins/kubernetes-actions-backend"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
