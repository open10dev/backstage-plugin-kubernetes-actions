{
  "name": "backstage-plugin-kubernetes-actions",
  "version": "0.1.0",
  "description": "A Backstage plugin that adds pod management (view status, delete) directly to catalog entity pages",
  "main": "src/index.ts",
  "keywords": [
    "backstage",
    "plugin",
    "kubernetes",
    "pods",
    "infrastructure",
    "devops"
  ],
  "homepage": "https://github.com/ruchit-mac/backstage-plugin-kubernetes-actions#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruchit-mac/backstage-plugin-kubernetes-actions"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.esm.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts"
  },
  "license": "Apache-2.0",
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "kubernetes-actions",
    "pluginPackages": [
      "backstage-plugin-kubernetes-actions",
      "backstage-plugin-kubernetes-actions-backend"
    ]
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "test": "backstage-cli package test",
    "lint": "backstage-cli package lint"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.8",
    "@backstage/core-plugin-api": "^1.12.4",
    "@backstage/frontend-plugin-api": "^0.15.1",
    "@backstage/plugin-catalog-react": "^1.21.6",
    "@material-ui/core": "^4.12.2",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "react": "^18.0.2",
    "react-use": "^17.2.4"
  },
  "peerDependencies": {
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/frontend-test-utils": "^0.5.1",
    "@backstage/test-utils": "^1.7.7",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18",
    "jest": "^29.7.0",
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.0.0"
  },
  "files": [
    "dist"
  ]
}
